{
  "cli": {
    "version": ">= 10.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": false,
        "buildConfiguration": "Debug",
        "image": "latest"
      },
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleDebug",
        "image": "latest"
      },
      "env": {
        "EXPO_PUBLIC_HAVEN_ENV": "development",
        "EXPO_PUBLIC_SUPABASE_URL": "http://127.0.0.1:54321",
        "EXPO_PUBLIC_SUPABASE_ANON_KEY": "REPLACE_WITH_LOCAL_SUPABASE_ANON_KEY"
      }
    },
    "preview": {
      "environment": "preview",
      "distribution": "internal",
      "ios": {
        "simulator": false,
        "buildConfiguration": "Release",
        "image": "latest"
      },
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease",
        "image": "latest"
      },
      "env": {
        "EXPO_PUBLIC_HAVEN_ENV": "staging",
        "EXPO_PUBLIC_SUPABASE_URL": "https://vaarqsmufctmjwnblynj.supabase.co",
        "EXPO_PUBLIC_ELDER_ID": "eee0afd7-0a80-4d25-9d50-8f604c37cf7a",
        "EXPO_PUBLIC_FAMILY_MEMBER_ID": "f4a7323f-88a6-4399-9561-70d89a0f273d"
      }
    },
    "production": {
      "environment": "production",
      "autoIncrement": true,
      "distribution": "store",
      "ios": {
        "simulator": false,
        "buildConfiguration": "Release",
        "image": "latest",
        "credentialsSource": "remote"
      },
      "android": {
        "buildType": "app-bundle",
        "gradleCommand": ":app:bundleRelease",
        "image": "latest",
        "credentialsSource": "remote"
      },
      "env": {
        "EXPO_PUBLIC_HAVEN_ENV": "production"
      }
    }
  }
}
