{
  "cli": {
    "version": ">= 10.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": false,
        "buildConfiguration": "Debug",
        "image": "latest"
      },
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleDebug",
        "image": "latest"
      },
      "env": {
        "EXPO_PUBLIC_HAVEN_ENV": "development",
        "EXPO_PUBLIC_SUPABASE_URL": "http://127.0.0.1:54321",
        "EXPO_PUBLIC_SUPABASE_ANON_KEY": "REPLACE_WITH_LOCAL_SUPABASE_ANON_KEY"
      }
    },
    "preview": {
      "environment": "preview",
      "distribution": "internal",
      "ios": {
        "simulator": false,
        "buildConfiguration": "Release",
        "image": "latest"
      },
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease",
        "image": "latest"
      },
      "env": {
        "EXPO_PUBLIC_HAVEN_ENV": "staging",
        "EXPO_PUBLIC_SUPABASE_URL": "https://vaarqsmufctmjwnblynj.supabase.co",
        "EXPO_PUBLIC_SUPABASE_ANON_KEY": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InZhYXJxc211ZmN0bWp3bmJseW5qIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODE4MTM5MDAsImV4cCI6MjA5NzM4OTkwMH0.w9oG4egDYwfqC2OOZ2-siqDo54u7wQKOM1bsBcRWgmI",
        "EXPO_PUBLIC_ELDER_ID": "00000000-0000-0000-0000-000000000001"
      }
    },
    "production": {
      "environment": "production",
      "autoIncrement": true,
      "distribution": "store",
      "ios": {
        "simulator": false,
        "buildConfiguration": "Release",
        "image": "latest",
        "credentialsSource": "remote"
      },
      "android": {
        "buildType": "app-bundle",
        "gradleCommand": ":app:bundleRelease",
        "image": "latest",
        "credentialsSource": "remote"
      },
      "env": {
        "EXPO_PUBLIC_HAVEN_ENV": "production"
      }
    }
  }
}
